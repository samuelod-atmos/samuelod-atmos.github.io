---
import BaseLayout from "../layouts/BaseLayout.astro";
import AtmosphereFlow from "../components/AtmosphereFlow";
---

<BaseLayout title="Atmosphere" showParticles={false}>
  <div style="position: relative; width: 100%; height: 100vh;">
    <AtmosphereFlow client:only="react" />
  </div>

  <section style="padding: 60px 20px; background: #0a0e27; color: #e0e0e0;">
    <div
      style="max-width: 900px; margin: 0 auto; text-align: center;"
    >
      <h2 style="color: #4285f4; margin-bottom: 20px;">Interactive Atmosphere</h2>
      <p style="font-size: 14px; line-height: 1.8; color: #b0b0b0;">
        Visualization of real-time wind patterns at 10-meter altitude, powered by
        <a
          href="https://open-meteo.com"
          target="_blank"
          rel="noopener"
          style="color: #4285f4; text-decoration: none; border-bottom: 1px solid #4285f4;"
        >
          Open-Meteo API
        </a>
        . Particle trajectories follow meteorological wind vectors, creating a
        scientifically-grounded yet aesthetically minimal representation of atmospheric
        flow. Drag to rotate, scroll to zoom.
      </p>
    </div>
  </section>
</BaseLayout>
